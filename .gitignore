# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local Claude Code settings (AGENTS.md / CLAUDE.md stay tracked — they are the build contract)
.claude/settings.local.json

# Intake drop-folder: CSV exports hold PII for every submission — never commit them
/intake/*
!/intake/README.md

# Client privacy rules are NOT here on purpose — the starter repo tracks
# clients/ and scripts/. The intake agent appends .gitignore.template on first
# run so a working clone never commits real client PII. See .gitignore.template.

# Python
__pycache__/
*.pyc
