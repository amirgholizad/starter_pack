# Copy to .env and fill in. .env is gitignored — never commit real keys.
# These vars are also read by the MCP servers in .mcp.json via ${VAR} expansion,
# so make sure they are exported in the shell that launches Claude Code
# (e.g. `set -a; source .env; set +a`, or use direnv).

# --- v0 (design generation) ---
# Get from https://v0.app  → account → API Keys
V0_API_KEY=

# --- Supabase MCP ---
# The Supabase MCP is the HOSTED server (see .mcp.json) and authenticates via
# OAuth — run `claude /mcp` in a real terminal to sign in. No token needed here.
# The target project is set by the project_ref in the .mcp.json URL; swap it
# per client — scripts/new-supabase-project.py does that swap for you.

# --- Supabase project provisioning (scripts/new-supabase-project.py) ---
# Personal access token used to CREATE a fresh project per client via the
# Management API (the MCP is pinned to one project and can't create them).
# Token: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
# Optional: skip org auto-detect / pick a default region for new projects.
# SUPABASE_ORG_ID=
# SUPABASE_REGION=us-east-1

# --- Supabase app runtime (used by the Next.js app at request time) ---
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — used by scripts/publish-assets.py to upload client images to a
# public Storage bucket so v0 can attach them. Server-side only; never commit.
SUPABASE_SERVICE_ROLE_KEY=
# Written automatically by new-supabase-project.py when it creates a project — a record
# of the new project's DB password (not read by the app; not retrievable from Supabase).
# DB_PASSWORD=

# --- Google Drive assets (scripts/fetch-drive-assets.py) ---
# rclone remote name for the Drive account that owns the intake form.
# Defaults to "gdrive" if unset; override here or with --remote.
# RCLONE_DRIVE_REMOTE=gdrive

# --- Vercel (deploy) ---
# Token: https://vercel.com/account/tokens  (only needed for non-interactive deploys)
# VERCEL_TOKEN=
